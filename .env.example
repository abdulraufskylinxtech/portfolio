# Public site URL (used in metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Content admin — /my-admin-section
ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: separate signing secret (defaults to ADMIN_PASSWORD)
# ADMIN_SECRET=another-long-random-string

# Contact form — Gmail SMTP (server-side only, never commit real values)
# 1. Enable 2FA on your Google account
# 2. Google Account → Security → App passwords → create one for "Mail"
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# Optional inbox override (defaults to email in data/site.json)
# CONTACT_TO_EMAIL=you@gmail.com

# JSON persistence on free serverless hosts (Vercel, etc.)
# Creates commits to data/*.json via GitHub Contents API — no database needed
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your-github-username
GITHUB_REPO=shakeel-ai-folio
# GITHUB_BRANCH=main
